{
    "configurations": [
        {
            "name": "Debug(MinGW64 UCRT)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Blackjack.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "D:\\CodeTool\\Tool\\MSYS2\\ucrt64\\bin;${env:PATH}"
                }
            ],
            "externalConsole": false,
            "preLaunchTask": "cmake:build",
            "miDebuggerPath": "D:\\CodeTool\\Tool\\MSYS2\\ucrt64\\bin\\gdb.exe",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": false
                }
            ]
        },
        {
            "type": "cmake",
            "request": "launch",
            "name": "Debug portfile(s)",
            "cmakeDebugType": "external",
            "pipeName": "\\\\.\\pipe\\vcpkg_ext_portfile_dbg",
            "preLaunchTask": "Debug vcpkg commands"
        }
    ]
}