{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake:configure",
            "command": "cmake",
            "type": "shell",
            "args": [
                "--preset",
                "Mingw-ucrt64-configurepreset",
                "-S",
                ".",
                "-B",
                "build",
                "-DCMAKE-BUILD_TYPE=Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": [],
            "detail": "Cmake配置生成构建文件到build目录"
        },
        {
            "label": "cmake:build",
            "command": "cmake",
            "type": "shell",
            "args": [
                "--build",
                "build",
                "-j4"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "dependsOn": [
                "cmake:configure"
            ],
            "dependsOrder": "sequence",
            "detail": "Cmake构建：编译build目录下的项目"
        }
    ]
}